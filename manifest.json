{
  "manifest_version": 3,
  "name": "LeetCode Sync (GitLeet)",
  "version": "1.0.0",
  "description": "Automatically syncs accepted LeetCode solutions to a user's GitHub repository.",
  "icons": {
    "16": "src/assets/icon16.png",
    "48": "src/assets/icon48.png",
    "128": "src/assets/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "LeetCode Sync Dashboard",
    "default_icon": {
      "16": "src/assets/icon16.png",
      "48": "src/assets/icon48.png"
    }
  },
  "options_page": "src/settings/index.html",
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*", "https://leetcode.com/submissions/*"],
      "js": ["src/content/injected.ts"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["src/content/index.ts"],
      "css": ["src/content/toast.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://leetcode.com/*", "https://api.github.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
