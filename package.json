{
  "name": "leetcommit-leetcode-extension",
  "private": true,
  "version": "1.0.0",
  "description": "Chrome Extension that automatically syncs accepted LeetCode solutions to a user's GitHub repository.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "package": "npm run build && node scripts/package.js"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  }
}
